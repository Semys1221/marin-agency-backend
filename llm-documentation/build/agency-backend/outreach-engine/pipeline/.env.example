# =============================================================================
# Pipeline — Environment Variables
# =============================================================================
# Copier ce fichier en .env.local et remplir les valeurs.
# main.py charge automatiquement .env.local depuis la racine du pipeline.

# === Tenant (optionnel - défaut: "sylk-conseils") ===
TENANT_ID=sylk-conseils

# === Supabase (obligatoire pour DB reads/writes) ===
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# === Scraping (Outscraper) ===
OUTSCRAPER_API_KEY=...

# === Email validation (MyEmailVerifier) ===
MYEMAILVERIFIER_API_KEY=...

# === Push (Instantly) ===
INSTANTLY_API_KEY=...

# === AI / Hermes (optionnel - base URL par défaut: http://localhost:8642/v1) ===
HERMES_API_KEY=...
HERMES_BASE_URL=http://localhost:8642/v1

# === Slack notifications (optionnel) ===
SLACK_BOT_TOKEN=...
SLACK_CHANNEL=#marin-pipeline
